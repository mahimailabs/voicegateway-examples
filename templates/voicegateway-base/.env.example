# voicegateway-base environment configuration
#
# Copy this file to '.env' (do not commit) and fill in real values.
# The agent loads these at startup via 'python-dotenv'.
#
# Provider API keys (Deepgram, OpenAI, Cartesia) are NOT set here. They
# are managed by 'voicegw' itself: run 'voicegw onboard' once to create
# a 'voicegw.yaml' project and add your provider keys. The factories in
# 'agent.py' look them up at construction time from the active project.

# LiveKit dev environment. Required for 'uv run agent.py dev' to register
# a worker and join a room. Use LiveKit Cloud or a local dev server.
LIVEKIT_URL=wss://your-livekit-deployment.example.com
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# VoiceGateway deployment endpoint. Read by examples that query the
# gateway's HTTP surface (for example '/v1/costs' at end of call).
VOICEGATEWAY_URL=https://your-voicegateway-deployment.example.com

# VoiceGateway authentication token. Treat like any other API key.
# Never commit a real value.
VOICEGATEWAY_TOKEN=your-voicegateway-token-here

# Optional model-string overrides. Defaults match 'agent.py' SWAP 3,
# so leaving these unset works out of the box. Format is 'provider/model'.
# STT_MODEL=deepgram/nova-3
# LLM_MODEL=openai/gpt-4o-mini
# TTS_MODEL=cartesia/sonic-3
# TTS_VOICE=f786b574-daa5-4673-aa0c-cbe3e8534c02
