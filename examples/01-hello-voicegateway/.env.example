# 01-hello-voicegateway environment configuration
#
# Copy this file to '.env' (do not commit) and fill in real credentials.
# The agent loads these at startup via 'python-dotenv'.

# Speech-to-text provider key. Sign up at https://deepgram.com.
DEEPGRAM_API_KEY=your-deepgram-api-key-here

# Large-language-model provider key. Sign up at https://platform.openai.com.
OPENAI_API_KEY=sk-your-openai-key-here

# Text-to-speech provider key. Sign up at https://cartesia.ai.
CARTESIA_API_KEY=your-cartesia-api-key-here

# VoiceGateway deployment endpoint. The example queries '/v1/costs' here at
# the end of each call to render the cost-by-modality summary.
VOICEGATEWAY_URL=https://your-voicegateway-deployment.example.com

# VoiceGateway authentication token. Treat like any other API key.
# Never commit a real value.
VOICEGATEWAY_TOKEN=your-voicegateway-token-here

# Optional model-string overrides. Defaults match the values in 'agent.py',
# so leaving these unset works out of the box. Uncomment to override.
# STT_MODEL=nova-2
# LLM_MODEL=gpt-4o-mini
# TTS_VOICE=f786b574-daa5-4673-aa0c-cbe3e8534c02
